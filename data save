CREATE DATABASE IF NOT EXISTS ghana_data_hub;
USE ghana_data_hub;

CREATE TABLE IF NOT EXISTS orders (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100),
    phone VARCHAR(20),
    network VARCHAR(50),
    plan VARCHAR(100),
    amount DECIMAL(10,2),
    reference VARCHAR(100),
    status VARCHAR(50),
    sms_status VARCHAR(50),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);